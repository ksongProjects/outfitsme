# Production runtime env for the app containers.
# Store this on the server as `/etc/outfitsme/app.env`.

FLASK_ENV=production
DEBUG=false
AWS_REGION=us-west-2
# Shared runtime env file is used by both containers. Compose pins backend/ frontend ports explicitly.
PORT=5000
DIAGNOSTICS_ENABLED=false
RATE_LIMIT_STORAGE_URI=memory://
ANALYSIS_QUEUE_URL=
MONTHLY_ANALYSIS_LIMIT=5
ENABLE_BEDROCK_ANALYSIS=false

DOMAIN=outfitsme.com
WWW_DOMAIN=www.outfitsme.com
APP_URL=https://outfitsme.com
NEXT_PUBLIC_APP_URL=https://outfitsme.com
# Leave blank for same-origin `/api` requests behind nginx.
NEXT_PUBLIC_API_BASE_URL=
# Public Better Auth origin used by the browser and for JWT issuer/audience checks.
BETTER_AUTH_URL=https://outfitsme.com
# Backend-only JWKS fetch URL. In Docker/Compose production, point this at the
# internal frontend service to bypass CDN/WAF 403s on `/api/auth/jwks`.
BETTER_AUTH_JWKS_URL=http://frontend:3000/api/auth/jwks
BETTER_AUTH_JWT_ISSUER=https://outfitsme.com
BETTER_AUTH_JWT_AUDIENCE=https://outfitsme.com

# Backend CORS should include the production domain(s) and any local preview URLs you use.
CORS_ALLOWED_ORIGINS=https://outfitsme.com,https://www.outfitsme.com

SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=outfit-images

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
SETTINGS_ENCRYPTION_KEY=
DEFAULT_ANALYSIS_MODEL=gemini-2.5-flash

# Better Auth / PostgreSQL
# Use the actual Postgres host or Supabase pooler host, not `https://<project-ref>.supabase.co`.
# Include the database name, usually `/postgres`.
DATABASE_URL=postgresql://user:password@db.<project-ref>.supabase.co:5432/postgres
BETTER_AUTH_SECRET=generate-a-long-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

CERTBOT_EMAIL=you@example.com
