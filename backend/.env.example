FLASK_ENV=development
PORT=5000
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=outfit-images
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
ITEM_IMAGE_MAX=3
SETTINGS_ENCRYPTION_KEY=
DEFAULT_ANALYSIS_MODEL=gemini-2.5-flash
# Better Auth configuration (PostgreSQL connection for session validation)
# Use the actual Postgres host or Supabase pooler host, not `https://<project-ref>.supabase.co`.
# Include the database name, usually `/postgres`.
DATABASE_URL=postgresql://user:password@db.<project-ref>.supabase.co:5432/postgres
