project_name = "outfitme"
environment  = "prod"
aws_region   = "us-east-1"

instance_type = "t3.small"

# App source repo for EC2 bootstrapping.
app_repo_url = "https://github.com/<your-org>/<your-repo>.git"
app_repo_ref = "main"

# SSM SecureString params that store full file contents.
backend_env_parameter  = "/outfitme/prod/backend_env"
frontend_env_parameter = "/outfitme/prod/frontend_env"

# If set, create Route53 records and serve app over your domain.
domain_name     = "app.example.com"
route53_zone_id = "Z1234567890ABCDE"
tls_email       = "ops@example.com"

# Cost guardrails.
monthly_budget_usd = "30"
budget_alert_email = "alerts@example.com"
# Confirm SNS email subscription after first apply.

# Edge protection.
enable_edge_protection = true
waf_rate_limit_per_5m  = 200

# Leave empty and use Session Manager when possible.
allow_ssh_cidr_blocks = []
