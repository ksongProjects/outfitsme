aws_region       = "us-east-1"
agent_name       = "outfitme-bedrock-agent"
agent_alias_name = "prod"

foundation_model = "anthropic.claude-3-5-sonnet-20240620-v1:0"

agent_instruction = <<-EOT
You are an outfit analysis assistant.
Analyze clothing in user-uploaded images and return strict JSON:
{"outfits":[{"style":"...","items":[{"category":"...","name":"...","color":"..."}]}]}
EOT

session_ttl_seconds = 900

# Optional: restrict invoke permissions to explicit model ARNs.
# If left empty, policy uses "*".
allowed_model_arns = []
